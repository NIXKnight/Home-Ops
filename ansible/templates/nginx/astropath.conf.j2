# astropath-dns-relay admin/API vhost. nginx terminates TLS with the wildcard
# cert from the top-level conf (http-level ssl_certificate — inherited here, so no
# per-vhost ssl_* directive, exactly like the OpenBao vhost). The FastAPI plane
# serves plain HTTP on 127.0.0.1:8080 (network_mode: host); uvicorn trusts the
# X-Forwarded-* headers set below only from ASTROPATH_FORWARDED_ALLOW_IPS (127.0.0.1).
upstream astropath {
  server 127.0.0.1:8080;
}

server {
  listen 80;
  listen [::]:80;
  server_name astropath.{{ ACME_DOMAIN_NAME }};
  return 301 https://$host$request_uri;
}
server {
  listen 443 ssl;
  listen [::]:443 ssl;
  server_name astropath.{{ ACME_DOMAIN_NAME }};

  # /metrics is LAN-allowlisted on top of the LAN-only 443 firewall opening:
  # Prometheus exposition must never leak beyond the trusted subnet(s).
  location /metrics {
{% for CIDR in ASTROPATH_METRICS_ALLOW_CIDRS %}
    allow {{ CIDR }};
{% endfor %}
    deny all;
    proxy_pass http://astropath;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location / {
    # The admin plane can return one-time secrets on create; never cache.
    add_header Cache-Control "no-store" always;
    proxy_pass http://astropath;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
