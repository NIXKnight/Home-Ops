# {{ ansible_managed }}
# astropath-dns-relay service environment (docker-compose env_file).
#
# Rendered 0600 root by playbooks/astropath.yml (no_log). Every key is an
# ASTROPATH_* variable consumed by astropath.settings.Settings — no invented
# names. Secret values (DSN, KEK, admin hash, session secret) come from the
# ansible-vault'd secrets-astropath.yml; the rest from config-astropath.yml.
#
# env_file values are consumed with `format: raw` (docker compose >= v2.30), so the
# argon2id hash and the Fernet KEK ship LITERALLY here — no `$`-escaping needed
# because that flag disables interpolation of the env_file contents.

# --- Bootstrap secrets (SecretStr; never logged) ---
ASTROPATH_DATABASE_DSN={{ ASTROPATH_DATABASE_DSN }}
ASTROPATH_CREDENTIAL_KEK={{ ASTROPATH_CREDENTIAL_KEK }}
ASTROPATH_ADMIN_PASSWORD_HASH={{ ASTROPATH_ADMIN_PASSWORD_HASH }}
ASTROPATH_SESSION_SECRET={{ ASTROPATH_SESSION_SECRET }}

# --- Management-plane CSRF origin check (enabled in production) ---
ASTROPATH_MANAGEMENT_ORIGIN={{ ASTROPATH_MANAGEMENT_ORIGIN }}

# --- Proxy-header trust: nginx source IP uvicorn honours X-Forwarded-* from ---
ASTROPATH_FORWARDED_ALLOW_IPS={{ ASTROPATH_FORWARDED_ALLOW_IPS }}

# --- RFC2136 listener (UDP + TCP), host-bound non-53 port ---
ASTROPATH_DNS_BIND={{ ASTROPATH_DNS_BIND }}
ASTROPATH_DNS_PORT={{ ASTROPATH_DNS_PORT }}

# --- FastAPI admin/API plane (loopback; behind the nginx vhost) ---
ASTROPATH_HTTP_BIND={{ ASTROPATH_HTTP_BIND }}
ASTROPATH_HTTP_PORT={{ ASTROPATH_HTTP_PORT }}

# --- Logging + graceful drain ---
ASTROPATH_LOG_LEVEL={{ ASTROPATH_LOG_LEVEL }}
ASTROPATH_LOG_FORMAT={{ ASTROPATH_LOG_FORMAT }}
ASTROPATH_SHUTDOWN_DRAIN_TIMEOUT={{ ASTROPATH_SHUTDOWN_DRAIN_TIMEOUT }}
